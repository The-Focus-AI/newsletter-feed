:0;margin-right:0;margin-left:0;font-family:Arial,sans-serif;line-height:30px;\" >\r\nIs the world ready for a car without a rear window?\r\n</h3>\r\n</div>\r\n</td>\r\n</tr>\r\n</table>\r\n</div>\r\n</td>\r\n</tr>\r\n</table>\r\n</div>\r\n<div style=\"display:none;\" >\r\n\r\n</div>\r\n<div style=\"margin-top:0;margin-bottom:0;margin-right:auto;margin-left:auto;max-width:640px;\" >\r\n<table align=\"center\" role=\"none\" style=\"width:100%;border-collapse:collapse;mso-table-lspace:0;mso-table-rspace:0;\" >\r\n<tr>\r\n<td style=\"padding-top:0;padding-bottom:0;padding-right:20px;padding-left:20px;text-align:center;border-collapse:collapse;mso-table-lspace:0;mso-table-rspace:0;\" >\r\n<div class=\"cp100 ogf\" style=\"text-align:left;display:inline-block;width:100%;\" >\r\n<table role=\"none\" width=\"100%\" style=\"border-collapse:collapse;mso-table-lspace:0;mso-table-rspace:0;\" >\r\n<tr>\r\n<td align=\"center\" class=\"img-fullwidth-editable\" style=\"padding-top:0;padding-bottom:4px;padding-right:0;padding-left:0;border-collapse:collapse;mso-table-lspace:0;mso-table-rspace:0;\" >\r\n<table role=\"none\" style=\"border-collapse:collapse;border-spacing:0;mso-table-lspace:0;mso-table-rspace:0;\" >\r\n<tr>\r\n<td style=\"width:600px;border-collapse:collapse;mso-table-lspace:0;mso-table-rspace:0;\" >\r\n<a href=\"https://10point.cmail19.com/t/d-l-gkkuhid-dknirndy-yd/\" style=\"text-decoration:underline;color:#015483;\" ><img src=\"https://i1.cmail19.com/ei/d/F8/F35/C87/csimport/RUMBLE.POLESTAR.175131.jpg\"  width=\"600\" label=\"Image — Fullwidth\" height=\"400\" style=\"border-width:0;display:block;outline-color:0;text-decoration:none;height:auto;width:100%;font-size:13px;line-height:100%;-ms-interpolation-mode:bicubic;\" /></a>\r\n</td>\r\n</tr>\r\n</table>\r\n</td>\r\n</tr>\r\n<tr>\r\n<td align=\"left\" class=\"caption\" style=\"padding-top:0;padding-bottom:16px;padding-right:0;padding-left:0;border-collapse:collapse;mso-table-lspace:0;mso-table-rspace:0;\" >\r\n<d