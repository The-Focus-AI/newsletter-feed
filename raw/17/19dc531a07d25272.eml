  "subject": "#4:There are no AI-native enterprises",
  "from": "\"🔳 Turing Post\" <turingpost@mail.beehiiv.com>",
  "to": "\"wschenk+test@thefocus.ai\" <wschenk+test@thefocus.ai>",
