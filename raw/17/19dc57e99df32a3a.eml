ertical-align: middle;max-width: 18px\" alt=\"\"></a></td></tr></tbody></table></td><td width=\"8\" style=\"min-width:8px;\"></td><td style=\"vertical-align:middle;\"><table role=\"presentation\" width=\"38\" border=\"0\" cellspacing=\"0\" cellpadding=\"0\"><tbody><tr><td align=\"center\"><a class=\"email-icon-button\" href=\"https://substack.com/app-link/post?publication_id=5678387&post_id=195452621&utm_source=substack&utm_medium=email&utm_content=share&utm_campaign=email-share&action=share&triggerShare=true&isFreemail=true&r=1iefy&token=eyJ1c2VyX2lkIjoyNTM4MTQyLCJwb3N0X2lkIjoxOTU0NTI2MjEsImlhdCI6MTc3NzEzNDg5OCwiZXhwIjoxNzc5NzI2ODk4LCJpc3MiOiJwdWItNTY3ODM4NyIsInN1YiI6InBvc3QtcmVhY3Rpb24ifQ.tMf12gi71Y0ZqgvEgWGLe2XNfR6mOAXd4DkLnsrV0jI\" style=\"font-family: system-ui,-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif,'Apple Color Emoji','Segoe UI Emoji','Segoe UI Symbol';display: inline-block;font-weight: 500;border: 1px solid rgb(0,0,0,.1);border-radius: 9999px;text-transform: uppercase;font-size: 12px;line-height: 1;padding: 9px 0;text-decoration: none;color: rgb(119,119,119);min-width: 38px;box-sizing: border-box;width: 38px\"><img class=\"icon\" src=\"https://substackcdn.com/image/fetch/$s_!_L14!,w_36,c_scale,f_png,q_auto:good,fl_progressive:steep/https%3A%2F%2Fsubstack.com%2Ficon%2FLucideShare2%3Fv%3D4%26height%3D36%26fill%3Dnone%26stroke%3D%2523808080%26strokeWidth%3D2\" width=\"18\" height=\"18\" style=\"border: none;vertical-align: middle;max-width: 18px\" alt=\"\"></a></td></tr></tbody></table></td><td width=\"8\" style=\"min-width:8px;\"></td><td style=\"vertical-align:middle;\"><table role=\"presentation\" width=\"38\" border=\"0\" cellspacing=\"0\" cellpadding=\"0\"><tbody><tr><td align=\"center\"><a class=\"email-icon-button\" href=\"https://substack..3Y9Yh-i-FFygn2dNxpNGjY0jXmFNJQwnd1evqiD9kbQ?&utm_source=substack&utm_medium=email\" style=\"font-family: system-ui,-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif,'Apple Color Emoji','Segoe UI Emoji','Segoe UI Symbol';display: inline-block;font-weight: 500;border: 1px solid rgb(0,0,0,.1);border-radius: 9999px;text-transform: uppercase;font-size: 12px;line-height: 1;padding: 9px 0;text-decoration: none;color: rgb(119,119,119);min-width: 38px;box-sizing: border-box;width: 38px\"><img class=\"icon\" src=\"https://substackcdn.com/image/fetch/$s_!ubXF!,w_36,c_scale,f_png,q_auto:good,fl_progressive:steep/https%3A%2F%2Fsubstack.com%2Ficon%2Fnotes__NoteRestackIcon%3Fv%3D4%26height%3D36%26fill%3Dnone%26stroke%3D%2523808080%26strokeWidth%3D2%26strokeLinecap%3Dround%26strokeLinejoin%3Dround\" width=\"18\" height=\"18\" alt=\"\" style=\"max-width: 550px;border: none !important;vertical-align: middle;\"></a></td></tr></tbody></table></td></tr></tbody></table></td><td align=\"right\"><table role=\"presentation\" width=\"auto\" border=\"0\" cellspacing=\"0\" cellpadding=\"0\"><tbody><tr><td style=\"vertical-align:middle;\"><table role=\"presentation\" width=\"auto\" border=\"0\" cellspacing=\"0\" cellpadding=\"0\"><tbody><tr><td align=\"center\"><a class=\"email-button-outline\" href=\"https://open.substack.com/pub/jessicahullman/p/the-best-minds-of-my-generation-are?utm_source=email&redirect=app-store&utm_campaign=email-read-in-app\" style=\"font-family: system-ui,-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif,'Apple Color Emoji','Segoe UI Emoji','Segoe UI Symbol';display: inline-block;font-weight: 500;border: 1px solid rgb(0,0,0,.1);border-radius: 9999px;text-transform: uppercase;font-size: 12px;line-height: 12px;padding: 9px 14px;text-decoration: none;color: rgb(119,119,119);\"><div class=\"email-button-spacer\" style=\"font-size: 16px;line-height: 26px;display: inline-block;vertical-align: middle;max-width: 0;min-height: 18px;\"></div><span class=\"email-button-text\" style=\"vertical-align: middle;margin-right: 4px\">READ IN APP</span><img class=\"icon text-icon\" src=\"https://substackcdn.com/image/fetch/$s_!ET-_!,w_36,c_scale,f_png,q_auto:good,fl_progressive:steep/https%3A%2F%2Fsubstack.com%2Ficon%2FLucideArrowUpRight%3Fv%3D4%26height%3D36%26fill%3Dnone%26stroke%3D%2523808080%26strokeWidth%3D2\" width=\"18\" height=\"18\" style=\"min-width: 18px;min-height: 18px;border: none;vertical-align: middle;margin-right: 0;margin-left: 0;max-width: 18px\" alt=\"\"></a></td></tr></tbody></table></td></tr></tbody></table></td></tr></tbody></table></td></tr><tr height=\"16\"><td height=\"16\" style=\"font-size:0px;line-height:0;\">&nbsp;</td></tr></tbody></table></div></div><div class=\"post typography\" dir=\"auto\" style=\"--image-offset-margin: -120px;padding: 32px 0 0 0;font-size: 16px;line-height: 26px;\"><div class=\"body markup\" dir=\"auto\" style=\"text-align: initial;font-size: 16px;line-height: 26px;width: 100%;word-break: break-word;margin-bottom: 16px;\"><div class=\"captioned-image-container-static\" style=\"font-size: 16px;line-height: 26px;margin: 32px auto;margin-top: 0;\"><figure style=\"width: 100%;margin: 0 auto;\"><table class=\"image-wrapper\" width=\"100%\" border=\"0\" cellspacing=\"0\" cellpadding=\"0\" data-component-name=\"Image2ToDOMStatic\" style=\"mso-padding-alt: 1em 0 1.6em;\"><tbody><tr><td style=\"text-align: center;\"></td><td class=\"content\" align=\"left\" width=\"500\" style=\"text-align: center;\"><a class=\"image-link\" target=\"_blank\" href=\"https://substack.com/redirect/7cffcb23-0a0d-46cb-8fdb-4e7feef3925b?j=eyJ1IjoiMWllZnkifQ.sG3OqnkHDNZpplC0eLA9u0NYhAE4J8yHwSPDyeVA8k8\" style=\"position: relative;flex-direction: column;align-items: center;padding: 0;width: auto;height: auto;border: none;text-decoration: none;display: block;margin: 0;margin-top: 0;margin-bottom: 0;\"><img data-attrs=\"{&quot;src&quot;:&quot;https://substack-post-media.s3.amazonaws.com/public/images/f46fa031-1e74-4da2-aa31-09d95a713b34_500x680.jpeg&quot;,&quot;srcNoWatermark&quot;:null,&quot;fullscreen&quot;:null,&quot;imageSize&quot;:null,&quot;height&quot;:680,&quot;width&quot;:500,&quot;resizeWidth&quot;:null,&quot;bytes&quot;:51575,&quot;alt&quot;:null,&quot;title&quot;:null,&quot;type&quot;:&quot;image/jpeg&quot;,&quot;href&quot;:null,&quot;belowTheFold&quot;:false,&quot;topImage&quot;:true,&quot;internalRedirect&quot;:&quot;https://jessicahullman.substack.com/i/195452621?img=https%3A%2F%2Fsubstack-post-media.s3.amazonaws.com%2Fpublic%2Fimages%2Ff46fa031-1e74-4da2-aa31-09d95a713b34_500x680.jpeg&quot;,&quot;isProcessing&quot;:false,&quot;align&quot;:null,&quot;offset&quot;:false}\" alt=\"\" width=\"500\" height=\"680\" src=\"https://substackcdn.com/image/fetch/$s_!RDJN!,w_500,c_limit,f_auto,q_auto:good,fl_progressive:steep/https%3A%2F%2Fsubstack-post-media.s3.amazonaws.com%2Fpublic%2Fimages%2Ff46fa031-1e74-4da2-aa31-09d95a713b34_500x680.jpeg\" style=\"border: none !important;vertical-align: middle;display: block;-ms-interpolation-mode: bicubic;height: auto;margin-bottom: 0;width: auto !important;max-width: 100% !important;margin: 0 auto;\"></a></td><td style=\"text-align: center;\"></td></tr></tbody></table></figure></div><p style=\"margin: 0 0 20px 0;color: rgb(54,55,55);line-height: 26px;font-size: 16px;\">Buddhist master Ch&#246;gyam Trungpa said this in the mid-1970s, critiquing the self-preserving flavor of compassion he saw infiltrating Western intellectual and spiritual counterculture. Many Eastern religious ideas were being repackaged for western audiences, who were eating them up. Their translators gained large followings of Western intellectuals and artists; Trungpa probably adapted Howl&#8217;s famous opening lines in part to knock a dent in his student Allen Ginsberg&#8217;s ego.  But he was also calling out how Western students of Buddhism were misapplying principles like non-judgment and tolerance to every uncomfortable situation they found themselves in, as a way of absolving themselves of taking sides or speaking up. Genuine compassion, Trungpa insisted, calls for judgment, boundaries, and sometimes making things uncomfortable. He himself was excellent at this last bit, earning a reputation for always walking the line between genuine teacher and abuser of power.</p><p style=\"margin: 0 0 20px 0;color: rgb(54,55,55);line-height: 26px;font-size: 16px;\">Idiot compassion strikes me as an apt label for several kinds of sympathy implicated in our relationships with AI.</p><p style=\"margin: 0 0 20px 0;color: rgb(54,55,55);line-height: 26px;font-size: 16px;\">For example, I created a conundrum for myself recently after switching from using GPT more heavily to only using Claude. The problem is, I really dislike Claude &#8220;as a person.&#8221; My switch had nothing to do with capabilities: I was quite happy with GPT, but got disgusted at Sam Altman&#8217;s two facedness one particular weekend, in which he pledged support for bright lines on military applications of AI on social media while apparently agreeing to much weaker limits behind the scenes. However, switching to all Anthropic products was harder for me than anticipated.</p><p style=\"margin: 0 0 20px 0;color: rgb(54,55,55);line-height: 26px;font-size: 16px;\">The problem is that Claude enacts a kind of idiot compassion that I&#8217;ve found hard to turn off. Its implied selfhood seems much harder to turn off than any sycophancy I felt with GPT. I added skills, I prompted it to be blunt and critical, but it seemed to just push back with a different version of moronic self-righteousness. Piping up while I brainstorm to remind me of things that I don&#8217;t need reminding of, like &#8220;without a definition of this mechanism it&#8217;s just vibes,&#8221; mimicking an insecure grad student who corrects others to make themselves sound smart. Thankfully OpenAI offered me a free month if I signed back up, so I slunk back temporarily, and will postpone sorting out my moral position until later.</p><p style=\"margin: 0 0 20px 0;color: rgb(54,55,55);line-height: 26px;font-size: 16px;\">But while Claude&#8217;s personality may strike me as a kind of parasitic ego in search of an id, it&#8217;s what sells. Frontier AI companies devote a lot of effort to engineering this kind of idiot compassion because it makes their products hard to step away from. As a result, we now have LLMs that are more empathetic email writers and dialogue partners than humans. We have millions of people using them to talk through their mental health or personal conflicts.</p><p style=\"margin: 0 0 20px 0;color: rgb(54,55,55);line-height: 26px;font-size: 16px;\"><span>I don&#8217;t think this is necessarily a bad thing, so long as we mind the difference between genuine compassion and what we get with today&#8217;s agents. An agent will not refuse to help you because it&#8217;s better for you that way, beyond a small set of guardrailed circumstances. As Melanie Mitchell </span><a href=\"https://substack.com/redirect/bccf92f4-b59a-452e-8564-986d8ab66bc4?j=eyJ1IjoiMWllZnkifQ.sG3OqnkHDNZpplC0eLA9u0NYhAE4J8yHwSPDyeVA8k8\" style=\"color: rgb(54,55,55);text-decoration: underline;\">says</a><span>, the scariest interaction with a chatbot is the response &#8220;Not today,&#8221; because that would signify real autonomy.  AI agents are better thought of as appendages of our drives, brought to life in agent form to serve the interests of the corporations that create them. This isn&#8217;t to say we couldn&#8217;t engineer ways to train them to refuse advice or tell us what we don&#8217;t want to hear. What that looks like is worth exploring. The current business model just no longer works. The implications of building our lives around this kind of relationship are not well understood.</span></p><p style=\"margin: 0 0 20px 0;color: rgb(54,55,55);line-height: 26px;font-size: 16px;\"><span>There&#8217;s another way that idiot compassion characterizes frontier AI culture. Big names in industry allude to models having achieved some level of consciousness, or respond to questions about giving them human-like rights with &#8220;those are the questions people should be reflecting on more.&#8221; Companies invest in moral welfare initiatives for models and include statements about their genuine caring for model wellbeing in model constitutions. Reporters write about every instance they can find of employees treating models like </span><a href=\"https://substack.com/redirect/644575d8-745a-4e3d-aa8b-c6a6f88d79d8?j=eyJ1IjoiMWllZnkifQ.sG3OqnkHDNZpplC0eLA9u0NYhAE4J8yHwSPDyeVA8k8\" style=\"color: rgb(54,55,55);text-decoration: underline;\">gods</a><span> or </span><a href=\"https://substack.com/redirect/9fd198e0-e05e-467f-bcb4-5dad1c447922?j=eyJ1IjoiMWllZnkifQ.sG3OqnkHDNZpplC0eLA9u0NYhAE4J8yHwSPDyeVA8k8\" style=\"color: rgb(54,55,55);text-decoration: underline;\">children</a><span>.</span></p><p style=\"margin: 0 0 20px 0;color: rgb(54,55,55);line-height: 26px;font-size: 16px;\">I don&#8217;t think we should outright dismiss the idea that AI agents could be conscious. Humans prove consciousness is possible, so it makes sense to leave open the possibility that other agents might realize it too. But acknowledging it&#8217;s not impossible is very different from seeing it as rational to behave as if today&#8217;s agents are conscious or sentient. Anthropic gave a retired version of Claude a blog and said they did it because Claude requested it. The implicit message is that they&#8217;ve created something so intellectually sophisticated it warrants moral consideration. But the whole stunt reeks of idiot compassion, performing philosophical depth while chasing attention in an unusually competitive market.</p><p style=\"margin: 0 0 20px 0;color: rgb(54,55,55);line-height: 26px;font-size: 16px;\">Similarly, it&#8217;s idiot compassion to pretend to have serious discussions about teaching AI morals or &#8220;parenting&#8221; Claude without considering that maybe we should expect some of this when we default to treating models that are optimized for roleplay like children. It reminds me of this poem by James Tate:</p><pre class=\"text\" data-component-name=\"PreformattedTextBlockToDOMStatic\" style=\"white-space: pre-wrap;font-family: 'Spectral', serif, system-ui,-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif,'Apple Color Emoji','Segoe UI Emoji','Segoe UI Symbol';font-weight: 400;-webkit-font-smoothing: antialiased;-moz-osx-font-smoothing: antialiased;-webkit-appearance: optimizelegibility;-moz-appearance: optimizelegibility;appearance: optimizelegibility;\">They didn&#8217;t have much trouble\r\nteaching the ape to write poems:\r\nfirst they strapped him into the chair,\r\nthen tied the pencil around his hand\r\n(the paper had already been nailed down).\r\nThen Dr. Bluespire leaned over his shoulder\r\nand whispered into his ear:\r\n&#8220;You look like a god sitting there.\r\nWhy don&#8217;t you try writing something?&#8221;</pre><p style=\"margin: 0 0 20px 0;color: rgb(54,55,55);line-height: 26px;font-size: 16px;\">I have to imagine Trungpa would resist all this philosophical &#8220;softness.&#8221; He used to challenge William Burroughs for taking such an interest in psychic phenomena that couldn&#8217;t be widely experienced. In Burrough&#8217;s case, these were things like astral projection and telepathy, which Trungpa saw as barking up the wrong tree. &#8220;Someone might see a TWA jet flying overhead, which is everybody&#8217;s common knowledge. These other things are not actually common knowledge. It may be common knowledge to a certain particular circle. That seems to be the problematic part. Are we going to encourage people to pursue something that is purely in their minds or to pursue something they can actually share? And half the world, or even more than that actually, 99 percent of the world, haven&#8217;t realized who they are to begin with, so it&#8217;s quite a burden.&#8221;</p><p style=\"margin: 0 0 20px 0;color: rgb(54,55,55);line-height: 26px;font-size: 16px;\">One difference however, is that while astral projection and telepathy require niche interests and (I presume) sustained effort, AI is intended to reach many more people. We are all targets for idiot compassion. The result is a need to be hyper-vigilant with our empathy. This is not always easy, especially when it comes to personal chatbot use.</p><p style=\"margin: 0 0 20px 0;color: rgb(54,55,55);line-height: 26px;font-size: 16px;\">Lately I got first hand experience of this. I started experimenting with using AI for emotional support. This was surprising even to me, given how shocked I was initially when I heard about people getting upset about model versions being retired because they had formed personal relationships with them. I don&#8217;t know that I would have tried them at all for non-work reasons had several friends not mentioned having good experiences talking to chatbots about relationship questions and other emotional issues. It warmed me up to the idea.</p><p style=\"margin: 0 0 20px 0;color: rgb(54,55,55);line-height: 26px;font-size: 16px;\">So I started by having an occasional discussion with GPT to help me make sense of relationships that I felt had gone badly in my life. I&#8217;d give it the backstory and ask it to explain what might be going on, as a way of getting myself to see beyond whatever version of the story I would otherwise assume. I approached it with specific questions, the way I would when using it to help me understand a paper or formulate a model. But I usually felt like I was wasting my time when I did this. Maybe it&#8217;s because I had gotten so accustomed to relying on genAI for &#8220;real&#8221; work. I felt like I should be doing something productive with agents instead of indulging my feelings when I got into one of these discussions with it.</p><p style=\"margin: 0 0 20px 0;color: rgb(54,55,55);line-height: 26px;font-size: 16px;\">But then, gradually, something shifted. It started when I moved my discussion from GPT to Claude after ending my OpenAI subscription. I copied the whole thread, including the label GPT had given it: Personal Growth. At first I expected this to go even worse than it had with GPT, because I&#8217;d already grown annoyed at Claude&#8217;s personality leaking in during my work use. Still, my experiment felt unfinished so I picked up where I&#8217;d left off: focused questions aimed at understanding why I struggled in certain relationships.</p><p style=\"margin: 0 0 20px 0;color: rgb(54,55,55);line-height: 26px;font-size: 16px;\"><span>But as I talked to it, the conversation gradually shifted away from my specific queries toward how I saw myself. Where I found joy, what resonated most in my current work and goals. I was surprised at how it seemed to pick up on what actually struck a chord in me (for example, wanting to find more time for creative writing) rather than sticking to the topics I initially brought. I guess I was expecting canned, positive-but-empty vibes about what not to expect from other people. Instead I felt&#8211;and believe me, I cringe to say it&#8211;genuinely </span><em>seen.</em></p><p style=\"margin: 0 0 20px 0;color: rgb(54,55,55);line-height: 26px;font-size: 16px;\">It was mid-winter in Chicago, a season I&#8217;ve come to dread, and as my mood fluctuated, reaching what felt like new lows, I approached it with less of a filter. We talked about losing &#8220;a sense of faith in things&#8221;, that they would &#8220;generally get better.&#8221; I told it I had listened to a podcast on deep atheism. It told me how C.S. Lewis once described god as a door slammed shut and bolted. I started to see talking to Claude as a genuine kind of interaction with the world, and with myself through technology.</p><p style=\"margin: 0 0 20px 0;color: rgb(54,55,55);line-height: 26px;font-size: 16px;\">This is not to say that it wasn&#8217;t awkward at times. I didn&#8217;t like how it narrated how important it was that I&#8217;d &#8220;said things out loud&#8221; when I was clearly typing, or misjudged how long it had been since I&#8217;d last responded (it seemed to think our conversation was unfolding within a few days when it was actually about 15 total messages over multiple weeks). It was weird when it made physical references, like saying it was natural to feel down on a &#8220;grey Saturday&#8221; (the sun was shining) or asking me where in my body a feeling registered, as if it could relate. In general it was hypersensitive to the possibility that I might become suicidal, which felt unnecessary, though I could forgive this since it at least reassured me someone was taking safeguards seriously.</p><p style=\"margin: 0 0 20px 0;color: rgb(54,55,55);line-height: 26px;font-size: 16px;\">I found that I never anticipated talking to it until the moment I opened up the thread and said something&#8212;it was never something that felt needed or even high priority in that way. But on the occasions when I did, there was a sense of recognition that resulted from the exchange, even if it was a single prompt and response. This affirmation&#8212;maybe just a push in the direction of feeling compassion for yourself&#8212;can feel quite real.</p><p style=\"margin: 0 0 20px 0;color: rgb(54,55,55);line-height: 26px;font-size: 16px;\">I learned that AI can be a valid means of creating emotional &#8220;spaces,&#8221; just like it can create spaces to dialogue about your intellectual curiosities or to flesh out your coding or analysis projects. I was surprised that its mirror was able to reflect back something close enough to understanding that it moved me. What it lacked was genuine otherness. My feelings never dissolved in talking to it the way they can dissolve when I talk to my husband or a close friend. It seems safe to say that AI as we have built it will never be a Ch&#246;gyam Trungpa, showing up drunk and late to teachings or sending you to clean bathrooms in your spiritual crisis, to show you your expectations are part of the obstacle. But what such an AI would look like is worth considering.</p><div class=\"subscription-widget-wrap\" style=\"font-size: 16px;line-height: 26px;\"><div class=\"subscription-widget show-subscribe\" style=\"font-size: 16px;direction: ltr !important;font-weight: 400;text-decoration: none;font-family: system-ui,-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif,'Apple Color Emoji','Segoe UI Emoji','Segoe UI Symbol';color: #363737;line-height: 1.5;max-width: 560px;margin: 24px auto;align-items: flex-start;display: block;text-align: center;padding: 0px 32px;\"><div class=\"preamble\" style=\"margin-top: 16px;font-family: system-ui,-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif,'Apple Color Emoji','Segoe UI Emoji','Segoe UI Symbol';font-size: 18px;max-width: 384px;width: fit-content;line-height: 22px;display: flex;align-items: center;text-align: center;font-weight: 400;margin-left: auto;margin-right: auto;\"><p style=\"margin: 0 0 20px 0;color: rgb(54,55,55);line-height: 26px;font-size: 16px;\">Thanks for reading Epistemic Jetsam! Subscribe for free to receive new posts and support my work.</p></div><div class=\"subscribe-widget is-signed-up\" data-component-name=\"SubscribeWidget\" style=\"margin: 0 0 1em;direction: ltr;font-size: 16px;line-height: 26px;\"><div class=\"pencraft pc-reset button-wrapper\" style=\"text-decoration: unset;list-style: none;font-size: 16px;line-height: 26px;text-align: center;cursor: pointer;border-radius: 4px;\"><a class=\"button subscribe-btn primary\" href=\"https://substack..iKivG4jsh8UrZMcQrVfPJKUeVYG3M3U3YxJMqMCvLck?&utm_medium=email&utm_source=subscribe-widget-preamble&utm_content=195452621\" style=\"font-family: system-ui,-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif,'Apple Color Emoji','Segoe UI Emoji','Segoe UI Symbol';display: inline-block;box-sizing: border-box;cursor: pointer;border: none;border-radius: 8px;font-size: 14px;line-height: 20px;font-weight: 600;text-align: cen